{
  "name": "exotica",
  "version": "1.0.0",
  "private": true,
  "description": "Exotica Agency — Brand Pulse Intelligence Platform & Agency Website",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:tracker": "pnpm --filter @exotica/tracker dev",
    "dev:api": "pnpm --filter @exotica/api dev",
    "build": "pnpm --parallel -r run build",
    "build:tracker": "pnpm --filter @exotica/tracker build",
    "build:api": "pnpm --filter @exotica/api build",
    "lint": "pnpm --parallel -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "db:migrate": "pnpm --filter @exotica/api prisma:migrate",
    "db:seed": "pnpm --filter @exotica/api prisma:seed",
    "db:generate": "pnpm --filter @exotica/api prisma:generate",
    "db:studio": "pnpm --filter @exotica/api prisma:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
